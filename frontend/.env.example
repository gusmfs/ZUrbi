# Copie para .env.local e preencha com sua chave do Google Cloud.
# Reinicie o Vite após alterar: npm run dev

# Chave Google Cloud: ative "Maps JavaScript API" e "Geocoding API" (endereço automático no mapa)
VITE_GOOGLE_MAPS_API_KEY=

# Opcional — URL do backend (vazio = proxy do Vite em /api → localhost:8080)
# VITE_API_URL=
