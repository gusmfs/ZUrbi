# ============================================================
# Zurbi — Variáveis de ambiente (desenvolvimento local)
# ============================================================
# ATENÇÃO: nunca comitar este arquivo com senhas reais.
# Adicione .env ao .gitignore se ainda não estiver.

# Banco de dados
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=zurbi_db
POSTGRES_USER=zurbi_user
POSTGRES_PASSWORD=zurbi_pass

# Spring Boot
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/zurbi_db
SPRING_DATASOURCE_USERNAME=zurbi_user
SPRING_DATASOURCE_PASSWORD=zurbi_pass

# MinIO / Storage
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zurbi-midias
MINIO_PUBLIC_URL=http://localhost:9000

# MinIO console: http://localhost:9001
# App: http://localhost:8080
